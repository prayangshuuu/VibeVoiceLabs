# Copy to .env:  cp .env.example .env
# Used by docker compose for build args and optional overrides.

# Browser-reachable URLs (host machine). The UI runs in your browser, so use
# localhost — not the Docker service name — unless you use a reverse proxy.
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/stream

# Force CPU inside Linux containers (no CUDA; no MPS in Docker on macOS)
VIBEVOICE_DEVICE=cpu
